{
  "name": "Jarvis String Gen Bot",
  "bb_sync_version": 2,
  "description": "A Telegram Bot to generate Telethon and Pyrogram String Session.",
  "author": "Your Name",
  "repository": "https://github.com/yourusername/yourrepo",
  "logo": "https://telegra.ph/file/83db3b7786ffa9948962b.jpg",
  "keywords": [
    "telegram",
    "bot",
    "python",
    "pyrogram",
    "telethon"
  ],
  "dependencies": {
    "python": "^3.10",
    "pyrogram": "^2.0",
    "telethon": "^1.25",
    "motor": "^3.3"
  },
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "A Bot's token from BotFather",
      "value": "",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID (Integer)",
      "value": "",
      "required": true
    },
    "MONGO_URL": {
      "description": "MongoDB connection URL",
      "value": "",
      "required": true
    },
    "MUST_JOIN": {
      "description": "Telegram channel/group the bot enforces users to join",
      "value": "",
      "required": true
    }
  },
  "database": {
    "type": "mongodb",
    "url": "MONGO_URL"
  }
}
